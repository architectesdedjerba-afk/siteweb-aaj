rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ==========================================
    // 1. GLOBAL HELPERS
    // ==========================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userExists() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return userExists() && (
        userDoc().get('role', 'member') == "admin" ||
        userDoc().get('role', 'member') == "super-admin"
      );
    }

    function isSuperAdmin() {
      return userExists() && userDoc().get('role', 'member') == "super-admin";
    }

    function isRepresentative() {
      return userExists() && userDoc().get('role', 'member') == "representative";
    }

    function isActive() {
      return userExists() && userDoc().get('status', 'pending') == "active";
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidUser(data) {
      return data.get('uid', '') is string &&
             data.get('displayName', '').size() < 100 &&
             data.get('displayName', '').size() > 0;
    }

    // ==========================================
    // 2. COLLECTION RULES
    // ==========================================

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();

      // Self-create: forced to role=member, status=pending
      allow create: if (
        isOwner(userId) &&
        incoming().get('role', 'member') == 'member' &&
        incoming().get('status', 'pending') == 'pending' &&
        isValidUser(incoming())
      ) || isAdmin();

      allow update: if isAdmin() || (
        isOwner(userId) &&
        isActive() &&
        incoming().get('role', existing().get('role', 'member')) == existing().get('role', 'member') &&
        incoming().get('status', existing().get('status', 'active')) == existing().get('status', 'active') &&
        isValidUser(incoming())
      );
      allow delete: if isAdmin();
    }

    match /news/{newsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /partners/{partnerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /commission_pvs/{pvId} {
      allow read: if isAdmin() || (isSignedIn() && isActive());
      allow write: if isAdmin() || (isRepresentative() && isActive());
    }

    match /contact_messages/{msgId} {
      allow get: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);

      allow create: if isSignedIn() && isActive() && incoming().userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /documents/{docId} {
      allow read: if isSignedIn() && isActive();
      allow write: if isAdmin();
    }

    match /profile_updates/{requestId} {
      allow get: if isAdmin() || (isSignedIn() && existing().uid == request.auth.uid);
      allow list: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);

      allow create: if isSignedIn() && isActive() && incoming().uid == request.auth.uid && incoming().status == 'pending';
      allow update, delete: if isAdmin();
    }

    // ==========================================
    // 3. PUBLIC FORMS (create open, read admin)
    // ==========================================

    match /event_registrations/{regId} {
      allow create: if incoming().keys().hasAll(['fullName', 'email', 'eventTitle', 'createdAt']) &&
                       incoming().fullName is string && incoming().fullName.size() > 0 && incoming().fullName.size() < 200 &&
                       incoming().email is string && incoming().email.matches('.+@.+\\..+') &&
                       incoming().eventTitle is string && incoming().eventTitle.size() < 300;
      allow read, update, delete: if isAdmin();
    }

    match /membership_applications/{appId} {
      allow create: if incoming().keys().hasAll(['fullName', 'email', 'phone', 'category', 'matricule', 'city', 'createdAt']) &&
                       incoming().fullName is string && incoming().fullName.size() > 0 && incoming().fullName.size() < 200 &&
                       incoming().email is string && incoming().email.matches('.+@.+\\..+') &&
                       incoming().category in ['Architecte', 'Architecte Stagiaire'] &&
                       incoming().get('status', 'pending') == 'pending';
      allow read, update, delete: if isAdmin();
    }

    match /partner_applications/{appId} {
      allow create: if incoming().keys().hasAll(['contactName', 'email', 'phone', 'companyName', 'activity', 'sponsorshipType', 'createdAt']) &&
                       incoming().contactName is string && incoming().contactName.size() > 0 && incoming().contactName.size() < 200 &&
                       incoming().email is string && incoming().email.matches('.+@.+\\..+') &&
                       incoming().companyName is string && incoming().companyName.size() < 300 &&
                       incoming().get('status', 'pending') == 'pending';
      allow read, update, delete: if isAdmin();
    }

    match /roles/{roleId} {
      allow read: if isSignedIn();
      allow create, update: if isSuperAdmin();
      allow delete: if isSuperAdmin() && existing().get('isSystem', false) == false;
    }

    // Allow connection test
    match /_connection_test_/{id} {
      allow read: if isSignedIn();
    }

    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
