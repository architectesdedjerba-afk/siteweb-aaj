{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Private profile information for a member architect.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "member", "representative"] },
        "status": { "type": "string", "enum": ["pending", "active", "suspended"] },
        "category": { "type": "string", "enum": ["Architecte", "Architecte Stagiaire"] },
        "licenseNumber": { "type": "string" },
        "mobile": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email", "role", "status"]
    },
    "NewsItem": {
      "title": "News Item",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "type": { "type": "string", "enum": ["Past", "Future"] },
        "category": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" }
      },
      "required": ["title", "date", "type"]
    },
    "Partner": {
      "title": "Partner",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "logoUrl": { "type": "string" },
        "category": { "type": "string", "enum": ["Platine", "Or", "Argent"] },
        "website": { "type": "string" }
      },
      "required": ["name", "category"]
    },
    "LibraryDocument": {
      "title": "Library Document",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "category": { "type": "string" },
        "subCategory": { "type": "string" },
        "fileType": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "url", "category", "fileType", "createdAt"]
    },
    "ProfileUpdateRequest": {
      "title": "Profile Update Request",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "userEmail": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "mobile": { "type": "string" },
        "category": { "type": "string" },
        "licenseNumber": { "type": "string" },
        "address": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "status", "createdAt"]
    },
    "EventRegistration": {
      "title": "Event Registration",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "eventTitle": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "email", "eventTitle", "createdAt"]
    },
    "MembershipApplication": {
      "title": "Membership Application",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "category": { "type": "string", "enum": ["Architecte", "Architecte Stagiaire"] },
        "matricule": { "type": "string" },
        "city": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "email", "phone", "category", "matricule", "city", "status", "createdAt"]
    },
    "PartnerApplication": {
      "title": "Partner Application",
      "type": "object",
      "properties": {
        "contactName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "companyName": { "type": "string" },
        "activity": { "type": "string" },
        "sponsorshipType": { "type": "string", "enum": ["platine", "or", "argent", "autre"] },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["contactName", "email", "phone", "companyName", "activity", "sponsorshipType", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "Private user profiles." },
    "/news/{newsId}": { "schema": "NewsItem", "description": "Public association news." },
    "/partners/{partnerId}": { "schema": "Partner", "description": "Public list of partners." },
    "/documents/{docId}": { "schema": "LibraryDocument", "description": "Documents (members only)." },
    "/commission_pvs/{pvId}": {
      "schema": { "type": "object", "properties": { "town": { "type": "string" }, "date": { "type": "string" }, "count": { "type": "number" }, "fileUrl": { "type": "string" } } },
      "description": "Commission meeting records."
    },
    "/contact_messages/{msgId}": {
      "schema": { "type": "object", "properties": { "userId": { "type": "string" }, "subject": { "type": "string" }, "message": { "type": "string" }, "createdAt": { "type": "string" } } },
      "description": "Internal messages."
    },
    "/profile_updates/{requestId}": { "schema": "ProfileUpdateRequest", "description": "Profile update requests." },
    "/event_registrations/{regId}": { "schema": "EventRegistration", "description": "Public event registrations." },
    "/membership_applications/{appId}": { "schema": "MembershipApplication", "description": "Public membership applications." },
    "/partner_applications/{appId}": { "schema": "PartnerApplication", "description": "Public partner applications." }
  }
}
