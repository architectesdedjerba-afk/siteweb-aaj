rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isActive() {
      return isSignedIn() &&
        firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.status == 'active';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function validImage() {
      return request.resource.size < 5 * 1024 * 1024 &&
             request.resource.contentType.matches('image/.*');
    }

    function validDoc() {
      return request.resource.size < 10 * 1024 * 1024 &&
             (request.resource.contentType == 'application/pdf' ||
              request.resource.contentType.matches('image/.*') ||
              request.resource.contentType.matches('application/msword') ||
              request.resource.contentType.matches('application/vnd.openxmlformats.*'));
    }

    // Public: logos, news images
    match /news/{file=**} {
      allow read: if true;
      allow write: if isAdmin() && validImage();
    }

    match /partners/{file=**} {
      allow read: if true;
      allow write: if isAdmin() && validImage();
    }

    // Member profile photos
    match /users/{userId}/{file=**} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) && isActive() && validImage();
    }

    // Library documents (members only)
    match /documents/{file=**} {
      allow read: if isSignedIn() && isActive();
      allow write: if isAdmin() && validDoc();
    }

    // Commission PVs
    match /commission_pvs/{file=**} {
      allow read: if isSignedIn() && isActive();
      allow write: if (isAdmin() || (isSignedIn() && isActive())) && validDoc();
    }

    // Contact message attachments
    match /contact_messages/{userId}/{file=**} {
      allow read: if isAdmin() || isOwner(userId);
      allow write: if isOwner(userId) && isActive() && validDoc();
    }

    // Membership applications (public upload — CV)
    match /membership_applications/{file=**} {
      allow read: if isAdmin();
      allow create: if validDoc();
    }

    // Deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
