# -----------------------------------------------------------------------------
# Frontend backend selection
# -----------------------------------------------------------------------------
# When set, the app routes public-form submissions (membership, event, partner)
# to the cPanel-hosted API. When empty/unset, the app falls back to Firestore
# (legacy behavior, kept for the migration window).
#
# Example:
#   VITE_API_BASE_URL=https://aaj-web.com/api
#
# See src/services/api.ts for the expected endpoint contract.
VITE_API_BASE_URL=

# -----------------------------------------------------------------------------
# Server-side secrets (NOT exposed to the client)
# -----------------------------------------------------------------------------
# Put these in .env.local (gitignored) for Cloud Functions / server use only.
# SENDGRID_API_KEY=...
# GEMINI_API_KEY=...
