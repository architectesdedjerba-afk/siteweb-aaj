# Frontend-only env vars.
# Copy to .env.local (gitignored) if you need to override defaults during local dev.
#
# Backend secrets (DB, JWT, SMTP) live in api/config.php on the server — NOT here.
# See api/config.example.php as the template.

# If the API is served from a different origin during local dev, point the
# frontend here (default: same-origin /api, set in src/lib/api.ts).
# VITE_API_BASE=https://aaj-web.com/api
